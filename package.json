  "scripts": {
    "format": "prettier --write \"*.html\" \"*.yml\" \"*.md\" \"_config.yml\" \"_includes/**/*.html\" \"_layouts/**/*.html\" \"_posts/**/*.markdown\" \"_futurePosts/**/*.markdown\" \"css/*.css\" \"js/*.js\" \"*.js\" \"shaders/**/*\""
