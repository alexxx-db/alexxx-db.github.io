    "grunt-contrib-less": "~0.11.4",
    "grunt-contrib-watch": "~0.6.1",
    "grunt-banner": "~0.2.3",
    "grunt-contrib-uglify": "~0.5.1"
  },
  "repository": {
    "type": "git",
