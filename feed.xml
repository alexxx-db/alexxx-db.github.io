---
layout: none
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <description>{{ site.description | xml_escape }}</description>
    <link>{{ site.url }}{{ site.baseurl }}/</link>
    <atom:link href="{{ site.url }}{{ site.baseurl }}/feed.xml" rel="self" type="application/rss+xml" />
    <pubDate>{{ site.time | date_to_rfc822 }}</pubDate>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    <generator>Jekyll v{{ jekyll.version }}</generator>
    {% for item in site.data.blogs %}
    <item>
      <title>{{ item.title | xml_escape }}</title>
      <link>{{ item.url | xml_escape }}</link>
      <guid isPermaLink="true">{{ item.url | xml_escape }}</guid>
      <pubDate>{{ item.date | date: "%a, %d %b %Y 00:00:00 +0000" }}</pubDate>
      <description>{{ item.description | default: item.title | xml_escape }}</description>
      <category>{{ item.source | xml_escape }}</category>
    </item>
    {% endfor %}
  </channel>
</rss>
